# Upstash Redis (automatisch von Vercel gesetzt nach Integration)
# Für lokale Entwicklung: Werte aus Vercel → Settings → Environment Variables kopieren
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternativ (Vercel-Integration setzt manchmal diese Namen):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
